# =============================================================================
#  DEVELOPMENT credentials template — copy to `.env.development`
#  Loaded when APP_ENV=development. Overrides the shared defaults in .env.
# =============================================================================

PORT=3000

# ---- Instagram app (platform Business Login) ----
IG_APP_ID=
IG_APP_SECRET=
IG_VERIFY_TOKEN=change-me-verify-token
# Local redirect (register it on the Meta app; use a tunnel like ngrok to expose it).
IG_OAUTH_REDIRECT_URI=https://localhost:5173/auth/instagram/callback

# Optional admin fallback account.
IG_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=
IG_PAGE_HANDLE=

# ---- Auth / internal API ----
API_KEY=change-me-api-key
AUTH_SECRET=change-me-to-a-long-random-secret

# ---- Google Sign-In (OAuth) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Platform admin ----
ADMIN_EMAIL=admin@example.com

# ---- Frontend + CORS ----
APP_PUBLIC_URL=http://localhost:5173
CORS_ORIGIN=*

# ---- MongoDB ----
MONGODB_URI=mongodb://127.0.0.1:27017

# ---- Razorpay (TEST keys: rzp_test_...) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID=
