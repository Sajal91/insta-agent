# Admin panel environment. Vite selects the file automatically by mode:
#   npm run dev    -> .env.development
#   npm run build  -> .env.production
# Copy the relevant example values into .env.development / .env.production.

# Base URL of the insta-agent backend API.
#   development: http://localhost:3000
#   production:  leave empty (SPA is served same-origin by the backend)
VITE_API_BASE_URL=http://localhost:3000

# Google OAuth Client ID (Web application) from Google Cloud Console.
# Used by Google Identity Services for the "Continue with Google" button.
# Must match GOOGLE_CLIENT_ID in the backend env for the same environment.
VITE_GOOGLE_CLIENT_ID=
