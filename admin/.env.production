# Admin panel — PRODUCTION (used by `npm run build`).
# The built SPA is served by the backend on the same origin, so the API base is
# left empty to use same-origin relative requests.
VITE_API_BASE_URL=

# Google OAuth Client ID (must match GOOGLE_CLIENT_ID in the backend .env.production).
VITE_GOOGLE_CLIENT_ID=812183271103-q0d9990umrlh4m0tko6mbe1jbqkt4k3a.apps.googleusercontent.com
