# =============================================================================
#  Base environment file (.env) — shared defaults + environment selector
# =============================================================================
# Copy this file to `.env`. The app runs in exactly two environments; the
# selector below decides which credential file is layered on top:
#
#   APP_ENV=development -> loads .env.development  (see .env.development.example)
#   APP_ENV=production  -> loads .env.production   (see .env.production.example)
#
# Load order (later overrides earlier):
#   .env  ->  .env.<APP_ENV>  ->  .env.local  ->  .env.<APP_ENV>.local
#
# A real OS/host env var (APP_ENV or NODE_ENV) always overrides the value here.

APP_ENV=development

# ---- Shared defaults (identical across environments) ----
LOG_LEVEL=info

IG_GRAPH_API_VERSION=v21.0
IG_GRAPH_BASE_URL=https://graph.instagram.com
IG_SCOPES=instagram_business_basic,instagram_business_manage_messages,instagram_business_manage_comments,instagram_business_content_publish

MONGODB_DB=insta_agent
AUTH_TOKEN_TTL_HOURS=12
RAZORPAY_CURRENCY=INR
