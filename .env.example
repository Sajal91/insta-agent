# ---- Server ----
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ---- Instagram Graph API (Meta) ----
# From your Meta App dashboard (App ID / App Secret).
IG_APP_ID=
IG_APP_SECRET=

# Long-lived access token for the connected Instagram Business/Creator account.
IG_ACCESS_TOKEN=

# The Instagram Business Account ID (IGSID / IG user id) that the bot posts as.
# Used to skip the bot's own comments. Find it via the Graph API (/me/accounts -> instagram_business_account).
IG_BUSINESS_ACCOUNT_ID=

# Your public @handle (without the @). Used in templates via {{pageHandle}}.
IG_PAGE_HANDLE=yourpage

# Graph API version to target, e.g. v21.0 (verify latest against Meta docs).
IG_GRAPH_API_VERSION=v21.0

# API host, depends on how you obtained the access token:
#   https://graph.instagram.com  -> Instagram API with Instagram Login (token starts with IGAA/IGQ)
#   https://graph.facebook.com   -> Instagram API with Facebook Login  (Page token, starts with EAA)
IG_GRAPH_BASE_URL=https://graph.instagram.com

# ---- Webhooks ----
# Arbitrary string you choose; must match what you enter in the Meta webhook config.
IG_VERIFY_TOKEN=change-me-verify-token

# ---- Internal API ----
# Protects the /reels, /templates, /logs, /flows, /reply routes (sent as x-api-key header).
API_KEY=change-me-api-key

# ---- Persistence (MongoDB) ----
# Connection string. Local: mongodb://127.0.0.1:27017
# Atlas: mongodb+srv://user:pass@cluster.xxxx.mongodb.net
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=insta_agent
