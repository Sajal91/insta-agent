# ---- Server ----
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ---- Instagram Graph API (ADMIN ACCOUNT ONLY) ----
# In the multi-tenant SaaS these belong ONLY to the admin's own Instagram account
# (the user whose email matches ADMIN_EMAIL). Every other user's credentials are
# entered by the admin in the panel and stored (encrypted) in MongoDB, per user.
# Leave these blank if the admin doesn't run their own automation.
IG_APP_ID=
IG_APP_SECRET=

# Long-lived access token for the ADMIN's connected Instagram Business account.
IG_ACCESS_TOKEN=

# The admin's Instagram Business Account ID (IGSID / IG user id).
IG_BUSINESS_ACCOUNT_ID=

# The admin's public @handle (without the @). Used in templates via {{pageHandle}}.
IG_PAGE_HANDLE=yourpage

# Graph API version to target, e.g. v21.0 (verify latest against Meta docs).
IG_GRAPH_API_VERSION=v21.0

# API host, depends on how you obtained the access token:
#   https://graph.instagram.com  -> Instagram API with Instagram Login (token starts with IGAA/IGQ)
#   https://graph.facebook.com   -> Instagram API with Facebook Login  (Page token, starts with EAA)
IG_GRAPH_BASE_URL=https://graph.instagram.com

# ---- Webhooks ----
# Verify token for the ADMIN's Meta app webhook config. Each other user brings
# their own verify token (stored per-user); any of them satisfies the handshake.
IG_VERIFY_TOKEN=change-me-verify-token

# ---- Internal API ----
# Optional programmatic access key (x-api-key header). Acts as the admin account.
API_KEY=change-me-api-key

# ---- Google Sign-In (OAuth) ----
# Everyone signs in with Google. Create an OAuth 2.0 Client ID (Web application)
# in Google Cloud Console. GOOGLE_CLIENT_ID must match the admin panel's
# VITE_GOOGLE_CLIENT_ID. GOOGLE_CLIENT_SECRET is optional (reserved for a future
# server-side code flow; the ID-token flow used here doesn't need it).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Admin / platform owner ----
# The Google account (email) that owns the platform. This user is auto-promoted
# to the admin role on login and owns the IG_* env credentials above. You can
# also promote any user to admin manually by setting role="admin" in MongoDB.
ADMIN_EMAIL=admin@example.com
# Secret used to sign session tokens (HMAC) AND encrypt stored per-user
# credentials. Use a long random string, e.g. `openssl rand -hex 32`. Keep it
# stable — changing it invalidates all stored user credentials.
AUTH_SECRET=change-me-to-a-long-random-secret
# Session token lifetime in hours.
AUTH_TOKEN_TTL_HOURS=12

# ---- Razorpay (monthly subscriptions) ----
# Keys from the Razorpay dashboard (use test keys first: rzp_test_...). Billing
# endpoints stay disabled until KEY_ID, KEY_SECRET and PLAN_ID are all set.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Secret you set when creating the webhook in the Razorpay dashboard. Required
# to verify incoming subscription webhooks.
RAZORPAY_WEBHOOK_SECRET=
# The monthly Plan id created once in the dashboard (e.g. plan_XXXXXXXXXXXX).
RAZORPAY_PLAN_ID=
# One-time setup fee charged on the first invoice, in paise (INR). 50000 = ₹500.
RAZORPAY_SETUP_FEE_PAISE=0
# Currency for the setup-fee addon; must match the plan's currency.
RAZORPAY_CURRENCY=INR

# Allowed origin(s) for the admin panel (CORS). "*" or comma-separated list,
# e.g. http://localhost:5173 for the Vite dev server.
CORS_ORIGIN=*

# ---- Persistence (MongoDB) ----
# Connection string.
#   Local:  mongodb://127.0.0.1:27017
#   Atlas:  mongodb+srv://<user>:<password>@<cluster>.xxxxx.mongodb.net/?retryWrites=true&w=majority
#
# ATLAS CHECKLIST (most connection failures are one of these):
#   1. Network Access: add your server's public IP (or 0.0.0.0/0 for a quick test).
#   2. Database user exists with a password (Database Access tab).
#   3. If the password has special characters (@ : / ? # % etc.), percent-encode
#      them in the URI. Example: "p@ss/w0rd" -> "p%40ss%2Fw0rd".
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=insta_agent

# Connection tuning (optional). Bump the timeout if Atlas is slow to reach.
MONGODB_SERVER_SELECTION_TIMEOUT_MS=15000
MONGODB_MAX_POOL_SIZE=10
