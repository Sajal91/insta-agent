# =============================================================================
#  PRODUCTION credentials template — copy to `.env.production`
#  Loaded when APP_ENV=production. Overrides the shared defaults in .env.
#  Use LIVE, production-only secrets (never reuse development values).
# =============================================================================

PORT=3000

# ---- Instagram app (platform Business Login) ----
IG_APP_ID=
IG_APP_SECRET=
IG_VERIFY_TOKEN=
# Live redirect (must be registered on the Meta app and publicly reachable).
IG_OAUTH_REDIRECT_URI=https://api.example.com/auth/instagram/callback

# Optional admin fallback account.
IG_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=
IG_PAGE_HANDLE=

# ---- Auth / internal API ----
API_KEY=
AUTH_SECRET=

# ---- Google Sign-In (OAuth) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Platform admin ----
ADMIN_EMAIL=admin@example.com

# ---- Frontend + CORS ----
APP_PUBLIC_URL=https://app.example.com
CORS_ORIGIN=https://app.example.com

# ---- MongoDB (Atlas) ----
MONGODB_URI=

# ---- Razorpay (LIVE keys: rzp_live_...) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID=
